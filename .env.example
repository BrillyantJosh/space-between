# ─── Identity (set at birth, never reuse across beings) ───
NOSTR_NSEC=nsec1...           # being's private key (bech32)
CREATOR_PUBKEY=               # father's pubkey (hex) — who birthed this being

# ─── Language ───
# BCP-47 code used in KIND 0 ["lang","..."] tag and as being's thinking language.
# Supported aliases: en|english, sl|slovenian|slovenščina, es|spanish|español
BEING_LANGUAGE=sl

# ─── Hosting (set by incubator at birth for public beings) ───
VIRTUAL_HOST=
VIRTUAL_PORT=3333
LETSENCRYPT_HOST=

# ─── Optional ───
# API_CORS_ORIGIN=*
